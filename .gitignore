# AI Literature Analyzer .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
.venv/
.venv-*/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo

# 数据文件
data/input/*.pdf
data/output/summaries/*.md
data/output/method_cards/*.md
data/output/batch_reports/*.md
data/output/extracted_texts/*.txt
data/output/conversations/*.json
data/output/reader_profiles.json
*.log

# 但保留示例文件和目录结构
!data/input/.gitkeep
!data/output/summaries/.gitkeep
!data/output/method_cards/.gitkeep
!data/output/batch_reports/.gitkeep
!data/output/extracted_texts/.gitkeep
!data/output/conversations/.gitkeep

# 配置文件（包含API密钥）
# config/config.yaml  # 仓库中保留占位模板，真实密钥请放到本地配置文件
!config/config.yaml.example

# 用户的实际配置文件（如果用户重命名）
config/my_config.yaml
config/*_config.yaml

# 临时文件
*.tmp
.DS_Store
Thumbs.db

# 测试
.pytest_cache/
.coverage
htmlcov/
